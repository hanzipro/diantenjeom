{
  "name": "@hanzi.pro/diantenjeom",
  "version": "0.1.0-rc.0",
  "description": "Punctuation-only CJK fonts, per locale. Drop into a font fallback chain.",
  "keywords": [
    "cjk",
    "font",
    "punctuation",
    "noto",
    "chinese",
    "japanese",
    "korean",
    "webfont",
    "typography"
  ],
  "license": "SIL-OFL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ethantw/diantenjeom.git"
  },
  "homepage": "https://github.com/ethantw/diantenjeom#readme",
  "type": "module",
  "main": "./dist/diantenjeom.css",
  "style": "./dist/diantenjeom.css",
  "exports": {
    ".": "./dist/diantenjeom.css",
    "./css": "./dist/diantenjeom.css",
    "./jis": "./dist/jis.css",
    "./moe": "./dist/moe.css",
    "./gb": "./dist/gb.css",
    "./kv": "./dist/kv.css",
    "./block": "./dist/block/diantenjeom.css",
    "./block/jis": "./dist/block/jis.css",
    "./block/moe": "./dist/block/moe.css",
    "./block/gb": "./dist/block/gb.css",
    "./block/kv": "./dist/block/kv.css",
    "./optional": "./dist/optional/diantenjeom.css",
    "./optional/jis": "./dist/optional/jis.css",
    "./optional/moe": "./dist/optional/moe.css",
    "./optional/gb": "./dist/optional/gb.css",
    "./optional/kv": "./dist/optional/kv.css",
    "./fonts/*": "./dist/fonts/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "fetch:sources": "python scripts/fetch_sources.py",
    "build": "python scripts/build_fonts.py && pnpm run sync:demo",
    "sync:demo": "rm -rf demo/fonts demo/diantenjeom.css && cp dist/diantenjeom.css demo/ && cp -R dist/fonts demo/fonts",
    "dev": "pnpm run sync:demo && serve -l 7001 demo",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "serve": "^14.2.6"
  }
}
